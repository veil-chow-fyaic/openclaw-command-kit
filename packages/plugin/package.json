    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@openclaw-commands/core": "*"
  },
  "peerDependencies": {
    "openclaw": ">=0.1.0"
  },
  "openclaw": {
