{
  "name": "@openclaw-commands/openclaw-command-kit",
  "version": "0.1.0",
  "description": "OpenClaw extension plugin providing /sessions and /resume commands.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/veil-chow-fyaic/openclaw-command-kit.git",
    "directory": "packages/plugin"
  },
  "bugs": {
    "url": "https://github.com/veil-chow-fyaic/openclaw-command-kit/issues"
  },
  "homepage": "https://github.com/veil-chow-fyaic/openclaw-command-kit/tree/main/packages/plugin#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@openclaw-commands/core": "*"
  },
  "peerDependencies": {
    "openclaw": ">=0.1.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/src/index.js"
    ]
  }
}
