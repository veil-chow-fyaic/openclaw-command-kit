{
  "name": "@openclaw-commands/openclaw-command-kit",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw extension plugin providing /sessions and /resume commands.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
