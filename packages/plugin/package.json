{
  "name": "@fyaic/openclaw-command-kit",
  "version": "0.1.2",
  "description": "OpenClaw extension plugin providing /sessions and /resume commands.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@fyaic/core": "^0.1.0"
  },
  "peerDependencies": {
    "openclaw": ">=0.1.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/src/index.js"
    ]
  }
}
